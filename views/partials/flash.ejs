<% /* reusable flash message partial with auto-dismiss */ %>
<% if (typeof error !== 'undefined' && error.length > 0) { %>
    <div class="flash-msg absolute top-5 left-1/2 -translate-x-1/2 -translate-y-1/2 p-3 rounded-md bg-red-500">
        <span class="inline-block mt-1 mb-1 text-white">
            <%= error %>
        </span>
    </div>
<% } %>
<% if (typeof success !== 'undefined' && success.length > 0) { %>
    <div class="flash-msg absolute top-5 left-1/2 -translate-x-1/2 -translate-y-1/2 p-3 rounded-md bg-blue-500">
        <span class="inline-block mt-1 mb-1 text-white">
            <%= success %>
        </span>
    </div>
<% } %>
<script>
    // auto remove flash after 2 seconds
    setTimeout(() => {
        const elem = document.querySelector('.flash-msg');
        if (elem) elem.remove();
    }, 2000);
</script>